@using Administracion_Consorcio_PW3.Models.ViewModels
@model RegistrarViewModel

@{
    ViewData["Title"] = "Registrar";
    Layout = "~/Views/Layouts/_BaseLayout.cshtml"; // Ruta completa al haber movido el archivo
}

<div class="flex items-center justify-center py-10 px-4">

    <div class="card w-full max-w-md">

        <h1 class="titulo-pagina text-center hover:opacity-80 transition-all">
            Crear Cuenta
        </h1>

        <form asp-action="Registrar" method="post" class="space-y-5">

            @* Muestra resumen de validaciones de DataAnnotations *@
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <div>
                <label class="block mb-2 font-semibold">
                    Email
                </label>
                <input asp-for="Email" placeholder="Ingrese su email"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="block mb-2 font-semibold">
                    Contraseña
                </label>
                <input asp-for="Password" placeholder="Ingrese su contraseña"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="block mb-2 font-semibold">
                    Confirmar Contraseña
                </label>
                <input asp-for="ConfirmarPassword" placeholder="Repita su contraseña"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                <span asp-validation-for="ConfirmarPassword" class="text-red-500 text-xs"></span>
            </div>

            <button type="submit" class="btn-principal w-full">
                Registrarse
            </button>

        </form>

        <div class="text-center mt-6">
            <p class="text-sm text-gray-600">
                ¿Ya tenés cuenta?
            </p>

            <a asp-action="Ingresar" class="inline-block mt-3 btn-secundario">
                Ingresar
            </a>
        </div>

    </div>

</div>

@section Scripts {
@* Importamos la librería SweetAlert2 *@
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@* Importamos validación del lado del cliente *@
<partial name="_ValidationScriptsPartial" />

@if (ViewBag.Error != null)
{
<script>
    @* Configuración de la alerta tipo Toast *@
        Swal.fire({
            icon: 'error',
            title: 'Ocurrió un error',
            text: '@ViewBag.Error',
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 4000,
            timerProgressBar: true
        });
</script>
}
}
