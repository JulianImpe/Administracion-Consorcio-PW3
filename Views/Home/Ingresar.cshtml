@using Administracion_Consorcio_PW3.Models.ViewModels
@model LoginViewModel
@* Define que esta vista recibe un objeto de tipo LoginViewModel *@

@{
    ViewData["Title"] = "Ingresar";
    Layout = "~/Views/Layouts/_BaseLayout.cshtml";
}

<div class="flex items-center justify-center py-10 px-4">

    <div class="card w-full max-w-md">

        <h1
            class="titulo-pagina text-center hover:opacity-80 transition-all">
            Iniciar Sesión
        </h1>

        <form asp-action="Ingresar" method="post" class="space-y-5">

            @* Muestra los errores generales del modelo *@
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <div>
                <label class="block mb-2 font-semibold">
                    Email
                </label>

                <input asp-for="Email" placeholder="Ingrese su email"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                @* Span para mostrar el error específico de este campo *@
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="block mb-2 font-semibold">
                    Contraseña
                </label>

                @* asp-for hereda el tipo 'password' del atributo [DataType] definido en el ViewModel *@
                <input asp-for="Password" placeholder="Ingrese su contraseña"
                    class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                @* Span para mostrar el error específico de la contraseña *@
                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
            </div>

            <button type="submit" class="btn-principal w-full">
                Ingresar
            </button>

        </form>

        <div class="text-center mt-6">
            <p class="text-sm text-gray-600">
                ¿No tenés cuenta?
            </p>

            <a asp-action="Registrar" class="inline-block mt-3 btn-secundario">
                Registrarse
            </a>
        </div>

    </div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<partial name="_ValidationScriptsPartial" />

@if (ViewBag.Error != null)
{
<script>
    Swal.fire({
        icon: 'warning',
        title: 'Atención',
        text: '@ViewBag.Error',
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 4000,
        timerProgressBar: true
    });
</script>
}

@if (TempData["Success"] != null)
{
<script>
    @* Toast de éxito usando SweetAlert2 *@
        Swal.fire({
            icon: 'success',
            title: '¡Logrado!',
            text: '@TempData["Success"]',
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 4000,
            timerProgressBar: true
        });
</script>
}
}
